# HomeFit Backend 환경변수 예시
# 실제 .env 파일은 절대 커밋하지 않는다. 이 파일(.env.example)만 관리한다.
# 값은 비워두고, 각자 로컬에서 .env로 복사해 채운다.
#   cp .env.example .env

# --- 서버 ---
NODE_ENV=development
PORT=3000

# --- DB (Prisma) ---
# PostgreSQL 예: postgresql://user:password@localhost:5432/homefit?schema=public
DATABASE_URL=

# --- 인증 (JWT Access/Refresh Token) ---
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=14d

# --- 소셜 로그인 (카카오/구글) ---
# 안드로이드 앱이 카카오/구글 SDK로 로그인 후 발급받은 토큰을
# 서버가 각 provider 서버에 검증하는 방식. 서버가 로그인 창을 띄우는 방식이 아니므로
# Redirect URI 등록은 필요 없다.
#
# 구글: 안드로이드 앱에 등록된 OAuth 2.0 클라이언트 중 "Web Client ID"를 사용한다.
#      (안드로이드 Client ID가 아니라 Web Client ID인 점 주의 - Google Sign-In이
#       ID Token을 발급할 때 audience로 찍히는 값이 Web Client ID다.)
GOOGLE_CLIENT_ID=
#
# 카카오: /v2/user/me 엔드포인트로 access token 자체를 검증하는 방식이라
#        REST API 키/시크릿을 서버에 등록할 필요는 없다. (참고용으로만 남겨둠)
# KAKAO_REST_API_KEY=

# --- Redis (BullMQ: 크롤링/알림 큐) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 크롤링 ---
# node-cron 실행 시각 (cron 식). 인수인계 기준 매일 06:00
CRAWL_CRON=0 6 * * *

# --- FCM 푸시 알림 ---
# 주의: 레거시 FCM_SERVER_KEY는 Google이 폐기함.
# 실제 구현 시 FCM HTTP v1(서비스 계정 JSON) 방식 권장.
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/fcm-service-account.json
FCM_PROJECT_ID=

# --- 금융상품 동기화 (POST /loan-products/sync-test, 개발용) ---
# 한국주택금융공사 전세자금대출 금리 정보 공공API
LOAN_RATE_API_BASE_URL=
LOAN_RATE_API_SERVICE_KEY=
# 한국주택금융공사 전세자금보증상품 상세정보 조회 공공API
LOAN_GUARANTEE_INFO_API_BASE_URL=