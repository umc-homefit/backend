# HomeFit Backend 환경변수 예시
# 실제 .env 파일은 절대 커밋하지 않는다. 이 파일(.env.example)만 관리한다.
# 값은 비워두고, 각자 로컬에서 .env로 복사해 채운다.
#   cp .env.example .env

# --- 서버 ---
NODE_ENV=development
PORT=3000

# --- DB (Prisma) ---
# 예: postgresql://user:password@localhost:5432/homefit
DATABASE_URL=

# --- 인증 (JWT) ---
JWT_SECRET=
JWT_EXPIRES_IN=7d

# --- Redis (BullMQ: 크롤링/알림 큐) ---
REDIS_HOST=localhost
REDIS_PORT=6379

# --- 크롤링 ---
# node-cron 실행 시각 (cron 식). 인수인계 기준 매일 06:00
CRAWL_CRON=0 6 * * *

# --- FCM 푸시 알림 ---
# 주의: 레거시 FCM_SERVER_KEY는 Google이 폐기함.
# 실제 구현 시 FCM HTTP v1(서비스 계정 JSON) 방식 권장.
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/fcm-service-account.json
FCM_PROJECT_ID=

# --- 금융상품 동기화 (POST /loan-products/sync-test, 개발용) ---
# 한국주택금융공사 전세자금대출 금리 정보 공공API
LOAN_RATE_API_BASE_URL=
LOAN_RATE_API_SERVICE_KEY=
